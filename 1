<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Outdoor Gear Inventory - Part 1</title>
    <style>
        /* 响应式设计：确保在窄屏和宽屏都能使用 [cite: 37] */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; padding: 20px; background: #eceff1; }
        .container { max-width: 900px; margin: auto; background: #fff; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h2 { color: #263238; border-bottom: 2px solid #455a64; padding-bottom: 10px; }
        
        /* 表单布局 */
        .form-group { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; }
        @media (max-width: 600px) { .form-group { grid-template-columns: 1fr; } } /* 手机端自动单列 [cite: 37] */
        
        input, select, button { padding: 12px; border: 1px solid #cfd8dc; border-radius: 6px; font-size: 14px; }
        button { cursor: pointer; transition: 0.3s; font-weight: bold; }
        .btn-add { background: #2e7d32; color: white; border: none; }
        .btn-add:hover { background: #1b5e20; }
        
        /* 消息提示区域 [cite: 38] */
        #displayMessage { margin: 15px 0; padding: 10px; border-radius: 4px; font-weight: 500; min-height: 24px; }
        .success { background: #c8e6c9; color: #2e7d32; }
        .error { background: #ffcdd2; color: #c62828; }

        /* 表格样式 */
        .table-scroll { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 13px; }
        th, td { border-bottom: 1px solid #eee; padding: 12px; text-align: left; }
        th { background: #455a64; color: white; }
        .popular-badge { background: #ffc107; padding: 2px 6px; border-radius: 4px; font-size: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Professional Outdoor Gear Inventory</h2>
        
        <div id="displayMessage"></div>

        <div class="form-group">
            <input type="text" id="itemId" placeholder="Item ID (Unique) *">
            <input type="text" id="itemName" placeholder="Item Name *">
            <select id="category">
                <option value="Electronics">Electronics</option>
                <option value="Furniture">Furniture</option>
                <option value="Clothing">Clothing</option>
                <option value="Tools">Tools</option>
                <option value="Miscellaneous">Miscellaneous</option>
            </select>
            <input type="number" id="quantity" placeholder="Quantity *">
            <input type="number" id="price" placeholder="Price *">
            <input type="text" id="supplier" placeholder="Supplier Name *">
            <select id="stockStatus">
                <option value="In Stock">In Stock</option>
                <option value="Low Stock">Low Stock</option>
                <option value="Out of Stock">Out of Stock</option>
            </select>
            <select id="isPopular">
                <option value="Yes">Popular: Yes</option>
                <option value="No">Popular: No</option>
            </select>
            <input type="text" id="comment" placeholder="Comment on item (Optional)" style="grid-column: span 2;">
        </div>

        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
            <button class="btn-add" onclick="addItem()">Add Gear</button>
            <button onclick="updateItem()">Update (by Name)</button>
            <button onclick="searchItem()">Search (by Name)</button>
            <button onclick="displayPopular()">Show Popular</button>
            <button onclick="renderTable(inventory)">Show All</button>
        </div>

        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>ID</th><th>Name</th><th>Category</th><th>Qty</th><th>Price</th><th>Status</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody id="inventoryBody"></tbody>
            </table>
        </div>
    </div>
    <script src="app.js"></script>
</body>
</html>